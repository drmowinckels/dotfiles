{
  "effortLevel": "medium",
  "env": {
    "R_LIBS_USER": "~/R/library",
    "GITHUB_PAT": "${GITHUB_PAT}"
  },
  "permissions": {
    "allow": [
      "Bash(R:*)",
      "Bash(Rscript:*)",
      "Bash(/opt/homebrew/bin/Rscript:*)",
      "Bash(/usr/local/bin/Rscript:*)",
      "Bash(/usr/local/bin/R:*)",
      "Bash(/Library/Frameworks/R.framework/Versions/4.5-arm64/Resources/bin/Rscript:*)",
      "Bash(RENV_PROFILE=default:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(hugo:*)",
      "Bash(quarto:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(pip3:*)",
      "Bash(uv:*)",
      "Bash(brew:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(sort:*)",
      "Bash(kill:*)",
      "Bash(export:*)",
      "Bash(file:*)",
      "Bash(xxd:*)",
      "Bash(for:*)",
      "Bash(if:*)",
      "Bash(zsh -c:*)",
      "WebFetch",
      "WebSearch",
      "Read(//Users/athanasm/**)",
      "Read(//Applications/**)",
      "Read(//opt/homebrew/**)",
      "Read(//Library/Frameworks/**)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "Read(//usr/local/bin/**)",
      "Bash(done)"
    ],
    "additionalDirectories": [
      "/tmp",
      "/Users/athanasm/Downloads"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; ext=\"${f##*.}\"; if echo \"$ext\" | grep -qE '^(html|scss|toml)$'; then dir=\"$f\"; while [ \"$dir\" != \"/\" ]; do dir=\"$(dirname \"$dir\")\"; if [ -f \"$dir/hugo.toml\" ] || [ -f \"$dir/config.toml\" ] || [ -f \"$dir/config/_default/hugo.toml\" ]; then cd \"$dir\" && hugo build --quiet 2>&1 | tail -5; exit $?; fi; done; fi; }",
            "timeout": 30,
            "statusMessage": "Verifying Hugo build..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "r-lib@posit-dev-skills": true,
    "quarto@posit-dev-skills": true,
    "shiny@posit-dev-skills": true,
    "open-source@posit-dev-skills": true,
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true,
    "writing-voices@straight-talk": true,
    "posit-dev@posit-dev-skills": true
  },
  "fileExclusions": [
    ".Rproj.user/**",
    ".Rhistory",
    ".RData",
    ".Ruserdata",
    "*_cache/**",
    "*.Rproj",
    "node_modules/**",
    ".git/**",
    "*.log",
    "revdep/**",
    "docs/**",
    "*.html",
    "*.pdf",
    ".httr-oauth",
    ".DS_Store",
    "public/**",
    "resources/**",
    ".hugo_build.lock"
  ]
}
